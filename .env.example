# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── Optional: Ports ──────────────────────────────────────────────────────────
# API_PORT=8000            # Host port for the FastAPI backend (default: 8000)
# DASHBOARD_PORT=3000      # Host port for the React dashboard (default: 3000)

# ── Optional: Data directory ─────────────────────────────────────────────────
# LITMUS_DATA_DIR=./data   # Host path for litmus.db + chroma/ (default: ./data)

# ── Optional: Project scoping ────────────────────────────────────────────────
# LITMUS_PROJECT_ID=       # Fixed project ID for the API server
